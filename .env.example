# Runtime mode: development | test | production
NODE_ENV=development

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=debug

# Telegram Bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=123456789:replace_with_real_token

# Optional extra Telegram bot tokens, comma-separated.
# Example: TELEGRAM_BOT_TOKENS=111111111:token_a,222222222:token_b
TELEGRAM_BOT_TOKENS=

# Allowed operator user IDs (required), comma-separated numbers
ALLOWED_USER_IDS=123456789

# Hub unix socket path used by Interface/Hub IPC
HUB_SOCKET_PATH=/tmp/hub-core.sock

# Monitor heartbeat interval in milliseconds
HEARTBEAT_INTERVAL_MS=10000

# Monitor service sync interval for instance registration (spawn/kill) in milliseconds
MONITOR_SYNC_INTERVAL_MS=1000

# Hub monitor update dispatch tick in milliseconds
MONITOR_PROGRESS_TICK_MS=1000

# Default per-chat monitor update interval for /update on (seconds)
MONITOR_UPDATE_DEFAULT_INTERVAL_SEC=30

# Allowed /update interval range in seconds
MONITOR_UPDATE_MIN_INTERVAL_SEC=5
MONITOR_UPDATE_MAX_INTERVAL_SEC=600

# Monitor alert threshold: consecutive heartbeat misses before reporting agent_error
HEARTBEAT_MISSED_THRESHOLD=3

# Base log directory for production file logs
LOG_DIR=/var/log/hub

# Optional default working directory used by spawned agents
# Example: AGENT_WORKDIR=/Users/yzliu/work/projects/my-repo
AGENT_WORKDIR=

# Optional Telegram webhook mode. Leave WEBHOOK_URL empty to keep long polling.
WEBHOOK_URL=
WEBHOOK_PORT=443
WEBHOOK_SECRET_TOKEN=

# Optional Web GUI server. Set WEB_GUI_ENABLED=true to start it.
WEB_GUI_ENABLED=false
WEB_GUI_PORT=3000

# Required when WEB_GUI_ENABLED=true. Used for deep links such as
# https://{WEB_GUI_HOST}:{WEB_GUI_PORT}/?thread={thread_id}&token={WEB_GUI_TOKEN}
WEB_GUI_HOST=
WEB_GUI_TOKEN=

# Enable HTTPS for the Web GUI. When true, both TLS paths must be set.
WEB_GUI_HTTPS=false
TLS_CERT_PATH=
TLS_KEY_PATH=

# Optional agent auth keys used in later tasks
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
CURSOR_API_KEY=
