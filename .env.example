# Runtime mode: development | test | production
NODE_ENV=development

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=debug

# Telegram Bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=123456789:replace_with_real_token

# Allowed operator user IDs (required), comma-separated numbers
ALLOWED_USER_IDS=123456789

# Hub unix socket path used by Interface/Hub IPC
HUB_SOCKET_PATH=/tmp/hub-core.sock

# Monitor heartbeat interval in milliseconds
HEARTBEAT_INTERVAL_MS=10000

# Monitor alert threshold: consecutive heartbeat misses before reporting agent_error
HEARTBEAT_MISSED_THRESHOLD=3

# Base log directory for production file logs
LOG_DIR=/var/log/hub

# Optional default working directory used by spawned agents
# Example: AGENT_WORKDIR=/Users/yzliu/work/projects/my-repo
AGENT_WORKDIR=

# Optional agent auth keys used in later tasks
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
CURSOR_API_KEY=
